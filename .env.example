# Spielbrett Monorepo — Environment Template
#
# Each app and the db-package have their own .env.
# Copy this file to:
#   apps/hub/.env       (DATABASE_URL relative to apps/hub/, i.e. "file:../../packages/db/dev.db")
#   apps/turnier/.env   (same path)
#   packages/db/.env    (DATABASE_URL relative to packages/db/, i.e. "file:./dev.db" for prisma CLI)
#
# In production (Pi), each app's .env points to an absolute path
# under /home/johannes/apps/data/spielbrett.db.

DATABASE_URL="file:./dev.db"
