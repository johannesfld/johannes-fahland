# Spielbrett Monorepo — Environment Template
#
# Each app and the db-package have their own .env, all pointing at the SAME
# Postgres database (Vercel Postgres / Neon). Copy this file to:
#   apps/hub/.env
#   apps/turnier/.env
#   packages/db/.env
#
# DATABASE_URL: pooled connection string, used by the Prisma Neon adapter at runtime.
# POSTGRES_URL_NON_POOLING: direct (non-pooled) connection string, used by
#   `prisma migrate` (packages/db) — migrations should not run through the pooler.

DATABASE_URL="postgres://user:password@host/db?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/db?sslmode=require"
